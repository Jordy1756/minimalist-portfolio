---
import CloseIcon from "@components/icons/CloseIcon.astro";

interface Props {
	id: string;
	title: string;
	class?: string;
}

const { id, title, class: className } = Astro.props;
---

<dialog
	id={id}
	closedby="any"
	class="top-1/2 left-1/2 max-h-[90vh] w-[min(90vw,700px)] -translate-x-1/2 -translate-y-1/2 overflow-hidden rounded-lg bg-neutral-50"
>
	<header
		class="sticky top-0 left-0 flex w-full items-center justify-between gap-4 border-b border-neutral-200 bg-neutral-50 p-4"
	>
		<h2 class="text-xl font-extrabold text-neutral-950">{title}</h2>
		<button command="close" commandfor={id} class="cursor-pointer">
			<CloseIcon width={24} class="text-neutral-950 transition-colors hover:text-neutral-700" />
		</button>
	</header>
	<section class:list={["max-h-[calc(90vh-100px)] overflow-y-auto p-4", className]}>
		<slot />
	</section>
</dialog>

<style>
	dialog {
		width: min(90vw, 700px);
	}
</style>
