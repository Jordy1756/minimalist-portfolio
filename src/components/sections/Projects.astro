---
import GithubIcon from "@components/icons/GithubIcon.astro";
import Section from "@components/layout/Section.astro";
import Card from "@components/ui/Card.astro";
import Link from "@components/ui/Link.astro";
import { getLangFromUrl, useTranslations } from "@i18n/utils.ts";
import type { Project } from "@scripts/entities/project.ts";

interface Props {
	projects: Project[];
}

const { projects } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Section title={t("projects.title")}>
	<div class="project-section grid gap-4">
		{
			projects.map(({ name, url, github, description, highlights }) => (
				<Card>
					<header class="flex items-center justify-between">
						<h3 class="flex text-lg font-bold text-neutral-800">
							{url ? (
								<Link
									href={url}
									class="flex items-center gap-2 hover:underline"
									title={t("projects.card.project.aria", name)}
									aria-label={t("projects.card.project.aria", name)}
								>
									{name}
								</Link>
							) : (
								name
							)}
						</h3>
						<Link
							href={github}
							title={t("projects.card.github.aria", name)}
							aria-label={t("projects.card.github.aria", name)}
						>
							<GithubIcon
								width={20}
								height={20}
								class="flex items-center gap-2 text-neutral-700 transition-colors hover:text-neutral-900"
							/>
						</Link>
					</header>
					<section class="mb-4 flex flex-1 flex-col gap-2">
						<p>{description}</p>
					</section>
					<footer>
						<ul class="flex flex-wrap gap-2 text-xs font-bold text-neutral-700">
							{highlights.map((highlight, index) => (
								<li class="flex gap-2">
									{index > 0 && <span>·</span>}
									<span>{highlight}</span>
								</li>
							))}
						</ul>
					</footer>
				</Card>
			))
		}
	</div>
</Section>

<style>
	.project-section {
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
	}
</style>
