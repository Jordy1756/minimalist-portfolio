---
import TimePeriod from "@components/ui/TimePeriod.astro";
import { getLangFromUrl } from "@i18n/utils";
import type { Education } from "@scripts/entities/education";

interface Props {
  education: Education;
}

const { education } = Astro.props;
const { institution, area, startDate, endDate } = education;

const lang = getLangFromUrl(Astro.url);

const localeCode = lang === "es" ? "es-ES" : "en-US";
const presentText = lang === "es" ? "Presente" : "Present";
---

<article>
  <header>
    <header class="flex justify-between gap-2">
      <div class="flex flex-col">
        <h3 class="text-lg font-semibold text-neutral-800">{institution}</h3>
      </div>
      <TimePeriod startDate={startDate} endDate={endDate} localeCode={localeCode} presentText={presentText} />
    </header>
  </header>
  <section>
    <p>{area}</p>
  </section>
</article>
