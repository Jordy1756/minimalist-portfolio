---
import Section from "@components/layout/Section.astro";
import EducationCard from "@components/sections/education/EducationCard.astro";
import { getLangFromUrl, useTranslations } from "@i18n/utils.ts";
import type { Education } from "@scripts/entities/education.ts";

interface Props {
	education: Education[];
}

const { education } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Section title={t("education.title")}>
	{
		education.map(({ institution, area, startDate, endDate }) => (
			<EducationCard
				institution={institution}
				area={area}
				startDate={startDate}
				endDate={endDate}
			/>
		))
	}
</Section>
