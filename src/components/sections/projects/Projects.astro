---
import ProjectCard from "@components/sections/projects/ProjectCard.astro";
import { getLangFromUrl, useTranslations } from "@i18n/utils.ts";
import type { Project } from "@scripts/entities/project.ts";

interface Props {
	projects: Project[];
}

const { projects } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section title={t("projects.title")}>
	<button command="show-modal" commandfor="projects-modal"> Ver todos los proyectos </button>
	<span slot="main-modal">Astro</span>
	<div class="project-section grid gap-4">
		{
			projects.map(({ name, url, github, description, highlights }) => (
				<ProjectCard
					name={name}
					url={url}
					github={github}
					description={description}
					highlights={highlights}
				/>
			))
		}
	</div>
</section>

<style>
	.project-section {
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
	}
</style>
