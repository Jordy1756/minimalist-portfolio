---
import Modal from "@components/ui/Modal.astro";
import type { Project } from "@scripts/entities/project";
import ProjectCard from "./ProjectCard.astro";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

const otherProjects = projects.filter((project) => !project.priority);
---

<Modal
  id="projects-modal"
  title="Todos los proyectos"
  class="grid grid-cols-[repeat(auto-fit,minmax(250px,1fr))] gap-4"
>
  {otherProjects.map((project) => <ProjectCard project={project} />)}
</Modal>
