---
import { getLangFromUrl, useTranslations } from "@i18n/utils.ts";
import GithubIcon from "@icons/GithubIcon.astro";
import type { Project } from "@scripts/entities/project.ts";

interface Props {
	project: Project;
}

const { project } = Astro.props;
const { name, description, highlights, url, github } = project;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<article class="flex flex-col gap-1 rounded-lg border border-neutral-200 p-4">
	<header class="flex items-center justify-between">
		<h3 class="flex text-lg font-bold text-neutral-800">
			{
				url ? (
					<a
						href={url}
						target="_blank"
						rel="noopener noreferrer"
						class="flex items-center gap-2 hover:underline"
						title={t("projects.card.project.aria", name)}
						aria-label={t("projects.card.project.aria", name)}
					>
						{name}
					</a>
				) : (
					name
				)
			}
		</h3>
		<a
			href={github}
			target="_blank"
			rel="noopener noreferrer"
			title={t("projects.card.github.aria", name)}
			aria-label={t("projects.card.github.aria", name)}
		>
			<GithubIcon
				width={20}
				height={20}
				class="flex items-center gap-2 text-neutral-700 transition-colors hover:text-neutral-900"
			/>
		</a>
	</header>
	<section class="mb-4 flex flex-1 flex-col gap-2">
		<p class="text-sm">{description}</p>
	</section>
	<footer>
		<ul class="flex flex-wrap gap-2 text-xs font-bold text-neutral-700">
			{
				highlights.map((highlight, index) => (
					<li class="flex gap-2">
						{index > 0 && <span>·</span>}
						<span>{highlight}</span>
					</li>
				))
			}
		</ul>
	</footer>
</article>
