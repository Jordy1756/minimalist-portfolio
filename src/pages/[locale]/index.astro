---
import AboutMe from "@components/sections/about-me/AboutMe.astro";
import Certificates from "@components/sections/certificates/Certificates.astro";
import Education from "@components/sections/education/Education.astro";
import Experience from "@components/sections/experience/Experience.astro";
import Hero from "@components/sections/hero/Hero.astro";
import Projects from "@components/sections/projects/Projects.astro";
import ProjectsGalleryModal from "@components/sections/projects/ProjectsGalleryModal.astro";
import Skills from "@components/sections/skills/Skills.astro";
import { getLangFromUrl, useTranslations } from "@i18n/utils.ts";
import Layout from "@layouts/Layout.astro";

export const getStaticPaths = async () => [{ params: { locale: "en" } }, { params: { locale: "es" } }];

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const resume = await import(`../../data/cv/${lang}.json`);
const { basics, experience, education, projects, certificates, skills } = resume;
---

<Layout title={`${t("home.head.title", basics.name)} - ${basics.label}`} locale={lang} basics={basics}>
  <Hero basics={basics} />
  <main class="flex flex-col gap-8">
    <AboutMe about={basics} />
    <Experience experience={experience} />
    <Projects projects={projects} />
    <Education education={education} />
    <Certificates certificates={certificates} />
    <Skills skills={skills} />
  </main>
  <ProjectsGalleryModal projects={projects} />
</Layout>
