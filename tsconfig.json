{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"paths": {
			"@components/*": ["./src/components/*"],
			"@data/*": ["./src/data/*"],
			"@i18n/*": ["./src/i18n/*"],
			"@layouts/*": ["./src/layouts/*"],
			"@styles/*": ["./src/styles/*"],
			"@scripts/*": ["./src/scripts/*"]
		}
	}
}
